<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <br><br>
        <h1> Create a new Listing</h1>
<body>
    <form method="POST" action="/listing" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input type="text" name = "listing[title]" class="form-control" placeholder="Enter your title" required>
        <div class="valid-feedback">looks-good </div>
        <div class="invalid-feedback">Enter a Title</div>
    </div>
        <div class="mb-3">
            <label for="textarea" class="form-label">Description</label>
            <textarea type="text" name = "listing[description]" class="form-control" placeholder="Enter your description" required></textarea>
            <div class="invalid-feedback">Enter a Description </div>
            <div class="valid-feedback">looks-good </div>
        </div>
             
        <div class="mb-3">
            <label for="image" class="form-label">Image Link</label>
            <input type="file" name = "listing[image]" class="form-control" placeholder="Enter image" required>
        </div>

        <div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input type="text" name = "listing[price]" class="form-control" placeholder="Enter your price" required>
            <div class="invalid-feedback">Enter a Valid price</div>
            <div class="valid-feedback">looks-good </div>
        </div>
        
        <div class="mb-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input type="text" name = "listing[country]" class="form-control" placeholder="Enter your country" required>
            <div class="invalid-feedback">Enter a valid country </div>
            <div class="valid-feedback">looks-good </div>
        </div>
        
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input type="text" name = "listing[location]" class="form-control" placeholder="Enter your Location" required>
            <div class="invalid-feedback">Enter a Valid Location </div>
            <div class="valid-feedback">looks-good </div>
        </div>
        </div>
        <button class="btn btn-dark add-btn mt-3">Submit</button>
        <br><br>
    </form>
</body>
</div>
</div>
