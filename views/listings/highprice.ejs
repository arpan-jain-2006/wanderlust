<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Expensive Listings</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f9f9f9;
            padding: 30px;
        }
        h2 {
            color: #333;
            margin-bottom: 20px;
        }
        ul {
            list-style: none;
            padding: 0;
        }
        li {
            background-color: #fff;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 6px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.1);
        }
        a {
            text-decoration: none;
            color: #0077cc;
            font-weight: bold;
        }
        a:hover {
            color: #004499;
        }
    </style>
</head>
<body>
    <h2>🏠 Expensive Listings (Above ₹4000)</h2>
    <ul>
        <% expensiveListings.forEach(listing => { %>
            <li>
                <a href="/listing/<%= listing._id %>">
                    <%= listing.title %> — ₹<%= listing.price %>
                </a>
            </li>
        <% }) %>
    </ul>
</body>
</html>

